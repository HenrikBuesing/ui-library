{
  "extends": "../../tsconfig-base.json",
  "compilerOptions": {
    "outDir": "./dist/",
    "emitDeclarationOnly": true,
    "paths": {
      "@hooks/*": ["./src/hooks/*"],
      "@utils/*": ["./src/utils/*"]
    },
    "rootDir": "./src"
  },
  "include": [
    "./src/components/**/index.ts",
    "./src/hooks/**/index.ts",
    "./src/index.ts",
    "./src/globals.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
  ]
}